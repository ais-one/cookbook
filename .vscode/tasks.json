    {
      "label": "sample-vue-minimal: build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/apps/sample-vue-minimal" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    // ── sample-vue-full ─────────────────────────────────────────────────────
    {
      "label": "sample-vue-full: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/apps/sample-vue-full" },
