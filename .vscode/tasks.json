      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "sample-api: test:integration",
      "type": "shell",
      "command": "npm run test:integration",
      "options": { "cwd": "${workspaceFolder}/apps/sample-api" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "sample-api: test (all)",
      "type": "shell",
      "command": "npm test",
      "options": { "cwd": "${workspaceFolder}/apps/sample-api" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    // ── sample-vue-minimal ──────────────────────────────────────────────────
    {
      "label": "sample-vue-minimal: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/apps/sample-vue-minimal" },
