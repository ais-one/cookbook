# also create for other modes as necessary
# e.g. mode=production then .env.production

VITE_APP_TITLE=Sample Vue Full
VITE_APP_DESCRIPTION=Sample Vue full-featured app
VITE_APP_KEYWORDS=vue,sample

# For Sentry - https://3326314072fc4706bf8492e292b674b2@o406131.ingest.sentry.io/5869551
VITE_SENTRY_DSN=

# API endpoint (.env.mocked: http://127.0.0.1:8080)
VITE_API_URL=http://127.0.0.1:3000

# same-origin, include=cross-origin
# if .env.mocked: same-origin
VITE_WITH_CREDENTIALS=include

# leave empty to disable web socket
# FastAPI
# VITE_WS_URL=wss://127.0.0.1:3000/api/ws
# ExpressJS
# VITE_WS_URL=ws://127.0.0.1:3000
VITE_WS_URL=
VITE_WS_MS=5000

BASE_PATH=/

# Initial routes after login/logout
VITE_INITIAL_SECURE_PATH=/dashboard
VITE_INITIAL_PUBLIC_PATH=/

# SSO - refresh url (internally implemented - for SAML2 and Password login, as there is no concept of refresh tokens)
VITE_REFRESH_URL=/api/auth/refresh

# Logout URL
VITE_LOGOUT_URL=/api/auth/logout

# NOT NEEDED... BACKEND DETERMINES VITE_USE_OTP, // GA, SMS, ''
# NOT NEEDED VITE_RECAPTCHA_KEY,
