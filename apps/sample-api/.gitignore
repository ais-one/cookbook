# ─── Template repo: generated output ─────────────────────────────────────────
# These files are produced by `npm run generate:crud` and `npm run docs:generate`.
# They are excluded here because this repo is a template — users are expected to
# run the generators themselves after cloning.
#
# The `student` files below are kept as a committed example so readers can see
# exactly what the generators produce without running them.
#
# In a real application, remove these ignores and commit your generated files.
# ─────────────────────────────────────────────────────────────────────────────

# Zod schemas generated from Drizzle columns
schemas/generated/
!schemas/generated/README.md
!schemas/generated/student.schema.js

# Express route files wired up with auth + validation middleware
src/routes/generated/
!src/routes/generated/README.md
!src/routes/generated/student.ts
!src/routes/generated/index.ts

# Drizzle query controllers (generated boilerplate, delegates to sidecar)
src/controllers/generated/
!src/controllers/generated/README.md
!src/controllers/generated/student.ts

# Sidecar controllers — generated once by generate:crud, re-export from generated/
# category.ts and student.ts are kept: category.ts is hand-written, student.ts is the example.
src/controllers/award.ts
src/controllers/categories.ts
src/controllers/country.ts
src/controllers/permissions.ts
src/controllers/roles.ts
src/controllers/state.ts
src/controllers/subject.ts
src/controllers/tenants.ts
src/controllers/users.ts

# Sidecar schemas — generated once by generate:crud, re-export from generated/
# categories.schema.js, student.schema.js, and webpush.schema.js are kept:
# the first two are hand-written / examples; webpush.schema.js is hand-written.
schemas/award.schema.js
schemas/country.schema.js
schemas/permissions.schema.js
schemas/roles.schema.js
schemas/state.schema.js
schemas/subject.schema.js
schemas/tenants.schema.js
schemas/users.schema.js

# OpenAPI spec — always an artifact, regenerate with: npm run docs:generate
docs/openapi/
