{
  // config loader accepts // comments, including inline end-of-line comments.
  "KNEXFILE_PG": {
    "client": "pg",
    "connection": ""
  },
  "KNEXFILE_MYSQL": {
    "client": "mysql",
    "connection": ""
  },
  // refer to keyv.config.md
  "KEYV_CACHE": {},
  // refer to redis.config.md
  "REDIS_CONFIG": "",
  "WS_OPTIONS": {},
  // service config types available: knex, keyv, redis, ws
  "SERVICES_CONFIG": {
    // "knex0": { "type": "knex", "options": "KNEXFILE_MYSQL" },
    "knex1": { "type": "knex", "options": "KNEXFILE_PG" },
    "keyv": { "type": "keyv", "options": "KEYV_CACHE" },
    "ws": { "type": "ws", "options": "WS_OPTIONS" }
  },
  // if withCredentials === false at Frontend
  // CORS_OPTIONS=
  // set withCredentials === true at Frontend
  //   exposedHeaders: ['refresh-token'], // allow this to be sent back in response
  //   maxAge, allowedHeaders, credentials, default cors settings
  //   credentials: true // Access-Control-Allow-Credentials value to true
  // SAMPLE: "allowedHeaders": ["content-type", "Authorization","access_token", "refresh_token"]
  // CORS - SAME ORIGIN - SERVED BY EXPRESS STATIC
  // CORS_OPTIONS: null
  // WEB_STATIC: 'public'
  // CORS - CROSS ORIGIN
  // CORS_OPTIONS { ..., withCredentials: true, origin: '127.0.0.1:8080' }
  // WEB_STATIC: ''
  "CORS_OPTIONS": {
    "methods": "GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS",
    "preflightContinue": false,
    "optionsSuccessStatus": 204,
    "credentials": true,
    "origin": ["http://127.0.0.1:8080", "https://127.0.0.1:8080"]
  },
  // additional response headers required...
  //// set Respons Headers, send if certain CORS headers are missing, to handle:
  //// https://www.alibabacloud.com/help/en/fc/overview-36 (CORS request processing)
  "RES_HEADERS_ADD": {
    "Access-Control-Allow-Origin": "*"
  },
  // serve static content - folder is relative to calling package.json
  // serve website from folder, blank if do not serve from express, last as path is /
  "WEB_STATIC": [
    {
      "folder": "../../node_modules/@common/iso",
      "url": "/esm"
    },
    {
      "folder": "public/openapi",
      "url": "/openapi",
      "options": {
        "icons": true,
        "list": true
      }
    },
    {
      "folder": "public/vue-nobundler",
      "url": "/native",
      "options": {
        "extensions": ["html"],
        "index": false
      }
    },
    {
      "folder": "public/demo-express",
      "url": "/"
    }
  ],
  // for file uploads - for production, use signed URL and object storage.
  "UPLOAD_STATIC": [
    {
      "url": "/uploads",
      "options": {
        "limits": {
          "files": 2,
          "fileSize": 10000000
        }
      },
      "list": true,
      "listOptions": {
        "icons": true
      }
    }
  ],

  "HELMET_OPTIONS": null,
  "HELMET_OPTIONS-NA": {
    "hideServer": true,
    "nosniff": true,
    "xssfilter": true,
    "csp": {
      "directives": {
        "defaultSrc": ["self"],
        "scriptSrc": ["self", "code.jquery.com", "maxcdn.bootstrapcdn.com"],
        "styleSrc": ["self", "maxcdn.bootstrapcdn.com"],
        "fontSrc": ["self", "maxcdn.bootstrapcdn.com"]
      }
    }
  },

  // port 8081 is from SAML
  // nip.io & localhost for fido2 testing
  "AUTH_ERROR_URL": "", // URL to redirect if error
  "SAML_PRIVATE_KEY": { "privateKey": "", "decryptionPvk": "" },

  "SAML_OPTIONS": {
    "idpCert": "<contents of idp-cert.pem>",
    "cert": "<contents of idp-cert.pem>",
    "callbackUrl": "http://127.0.0.1:3000/api/saml/callback",
    "entryPoint": "http://127.0.0.1:7000/saml/sso",
    "identifierFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress",
    "issuer": "http://127.0.0.1:3000",
    "wantAuthnResponseSigned": true,
    "wantAssertionsSigned": false,
    "signatureAlgorithm": "sha256"
  },
  "SAML_OPTIONS_ORG": {
    "idpCert": "<Get From http://127.0.0.1:8081/realms/dev/protocol/saml/descriptor>",
    "cert": "<Get From http://127.0.0.1:8081/realms/dev/protocol/saml/descriptor>",
    "callbackUrl": "http://127.0.0.1:3000/api/saml/callback",
    "entryPoint": "http://127.0.0.1:8081/realms/dev/protocol/saml",
    "identifierFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:unspecified",
    "issuer": "dev-client-saml",
    "wantAuthnResponseSigned": true,
    "wantAssertionsSigned": false,
    "signatureAlgorithm": "sha256"
  },
  "SAML_JWT_MAP": {
    "id": "nameID",
    "groups": "Role"
  },
  // OIDC - SECRET
  // NOTE: need to setup keycloak for OIDC see readme in docker-devenv folder
  // For SPA - http://127.0.0.1:8080/callback
  // For express hosted sample frontend - http://127.0.0.1:3000/sso.html
  // OIDC_OPTIONS=
  // - REISSUE = tokens issued by app instead of IDP, refresh endpoint also handled by app
  // - ID_NAME = the property name for user id in oidc token from IDP
  "OIDC_OPTIONS": {
    "URL": "http://127.0.0.1:4000",
    "CLIENT_ID": "my-app",
    "CLIENT_SECRET": "my-app-secret",
    "CALLBACK": "http://127.0.0.1:3000/api/auth/oidc/callback",
    "REISSUE": true,
    "ID_NAME": "sub"
  },
  "OIDC_OPTIONS_ORG": {
    "URL": "http://127.0.0.1:8081/realms/dev/protocol/openid-connect",
    "CLIENT_ID": "dev-client-oidc",
    "CLIENT_SECRET": "<REDACTED>",
    "CALLBACK": "http://127.0.0.1:3000/sso.html",
    "REISSUE": true,
    "ID_NAME": "preferred_username"
  },
  // OAuth - SECRET (we use github for example)
  // For SPA - http://127.0.0.1:8080/callback
  // For express hosted sample frontend - http://127.0.0.1:3000/sso.html
  "OAUTH_OPTIONS": {
    "URL": "https://github.com/login/oauth/access_token",
    "CLIENT_ID": "a355948a635c2a2066e2",
    "CLIENT_SECRET": "<REDACTED>",
    "CALLBACK": "http://127.0.0.1:3000/sso.html",
    "USER_URL": "https://api.github.com/user",
    "USER_ID": "id",
    "USER_GROUPS": "",
    "FIND_ID": "githubId"
  },

  "T4T": {
    "CONFIGS_FOLDER_PATH": "./apps/app-t4t/tables/",
    "CONFIGS_CSV_SIZE": 500000,
    "CONFIGS_UPLOAD_SIZE": 8000000,
    "CUSTOM_PATH": "./custom"
  },
  "BODYPARSER_JSON": { "limit": "2mb" }, // example inline comment
  "BODYPARSER_URLENCODED": { "extended": true, "limit": "2mb" },

  // comma seperated routes to ignore e.g. '/api/healthcheck,/api/test'
  "BODYPARSER_RAW_ROUTES": "",

  // https://web.dev/samesite-cookies-explained/
  "COOKIE_OPTS": {
    "httpOnly": true, // # (also set on FE... credentials if cross origin, true means) - DO TAKE NOTE OF CORS
    "sameSite": "lax", // Strict => CORS_OPTIONS === null, Lax, None => CORS_OPTIONS !== null
    "secure": false, // true if sameSite=None
    "maxAge": 0, // no expiry, deleted on browser close. Otherwise in ms
    "domain": "" // current domain only, e.g. .example.com for subdomain sharing
  },

  "JWT": {
    "JWT_ALG": "HS256", // 'ES256' (use SSL certs), 'HS256' (use secret string)
    "JWT_EXPIRY_SEC": "45m", // 5s (test refresh) // 1800 // d, h, m, s, small expiry to test refresh, numeric is seconds
    "JWT_REFRESH_EXPIRY_SEC": 3600, // in seconds //  10 (test refresh) // do not allow refresh if expired
    "JWT_REFRESH_STORE_TYPE": "keyv", // keyv (default, can also use redis in keyv), or knex
    "JWT_REFRESH_STORE_NAME": "user_session", // collection or table name
    "JWT_REFRESH_TOKEN_BYTE_LEN": 32, // 32 bytes = 256 bits, which is secure for random tokens
    "JWT_ISS": "", // issuer — e.g. "https://api.example.com"
    "JWT_AUD": "", // audience — e.g. "https://app.example.com"
    "JWT_SCOPE": "openid profile email" // space-separated scopes
  },

  // OpenFGA fine-grained authorization
  // Start server: docker run -p 8080:8080 openfga/openfga run
  // Leave storeId/authorizationModelId blank to disable FGA (falls back to DB roles column).
  // Populate them after running the initial_openfga seed or via FGA Playground.
  "FGA_CONFIG": {
    "apiUrl": "http://127.0.0.1:8080",
    "storeId": "", // set after running initial_openfga seed
    "authorizationModelId": "" // set after running initial_openfga seed
  },

  // DB-backed RBAC — tenant-scoped roles and permissions.
  // Set enabled=true after running migration 20260416000001_rbac_tables
  // and seed initial_rbac.js.
  // When enabled, createToken embeds active_tenant + tenants map in the JWT.
  // Can be used alongside FGA (coarse-grained RBAC + fine-grained FGA).
  "RBAC_CONFIG": {
    "enabled": false
  }
}
