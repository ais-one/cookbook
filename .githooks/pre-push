#!/bin/sh
# .githooks/pre-push
# Pre-push hook: runs unit tests and schema validation tests before allowing a push.
#
# Install: run .githooks/setup.sh (or: git config core.hooksPath .githooks)
# Skip:    git push --no-verify

HOOK_NAME=pre-push
# shellcheck source=.githooks/_common.sh
. "$(dirname "$0")/_common.sh"

# ── 1. Unit tests for impacted workspaces ─────────────────────────────────────
print_info "Detecting impacted workspaces…"

EMPTY_TREE="4b825dc642cb6eb9a060e54bf8d69288fbee4904"
CHANGED_FILES=""

while read -r local_ref local_sha remote_ref remote_sha; do
  # Deleting a branch – nothing to test
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    FILES=$(git diff --name-only "$EMPTY_TREE" "$local_sha" 2>/dev/null)
  else
    FILES=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null)
  fi
  CHANGED_FILES=$(printf '%s\n%s' "$CHANGED_FILES" "$FILES")
done

CHANGED_FILES=$(printf '%s\n' "$CHANGED_FILES" | sort -u | grep -v '^$')

IMPACTED_WS=""
for WS_DIR in apps/* common/*; do
  [ -d "$WS_DIR" ] || continue
  [ -f "$WS_DIR/package.json" ] || continue
  if printf '%s\n' "$CHANGED_FILES" | grep -q "^${WS_DIR}/"; then
    IMPACTED_WS="$IMPACTED_WS $WS_DIR"
  fi
done

if [ -z "$IMPACTED_WS" ]; then
  print_warning "No workspace files changed – skipping unit tests."
else
  TEST_EXIT=0
  for WS in $IMPACTED_WS; do
    if node -e "const p=require('./${WS}/package.json'); process.exit(p.scripts&&p.scripts['test']?0:1)" 2>/dev/null; then
      print_info "Running tests for workspace: $WS"
      npm run test --workspace="$WS"
      if [ $? -ne 0 ]; then
        print_error "Tests failed for workspace: $WS"
        TEST_EXIT=1
      else
        print_success "Tests passed for workspace: $WS"
      fi
    else
      print_warning "No 'test' script in $WS – skipping."
    fi
  done

  if [ $TEST_EXIT -ne 0 ]; then
    print_error "Fix failing tests before pushing. Use 'git push --no-verify' to bypass."
    exit 1
  fi
fi

print_success "Unit tests passed."

# ── 2. Schema validation tests ────────────────────────────────────────────────
# Run schema tests for all known schema directories that exist in the repo.
if node -e "const p=require('./package.json'); process.exit(p.scripts&&p.scripts['test:schemas']?0:1)" 2>/dev/null; then
  print_info "Running schema validation tests…"
  SCHEMA_DIRS=""
  [ -d "common/schemas" ] && SCHEMA_DIRS="$SCHEMA_DIRS common/schemas"
  for DIR in apps/*/schemas; do
    [ -d "$DIR" ] && SCHEMA_DIRS="$SCHEMA_DIRS $DIR"
  done

  if [ -z "$SCHEMA_DIRS" ]; then
    print_warning "No schema directories found – skipping schema tests."
  else
    SCHEMA_EXIT=0
    for SCHEMA_DIR in $SCHEMA_DIRS; do
      npm run test:schemas -- "$SCHEMA_DIR"
      if [ $? -ne 0 ]; then
        print_error "Schema validation tests failed for $SCHEMA_DIR. Fix schema errors before pushing."
        SCHEMA_EXIT=1
      else
        print_success "Schema validation tests passed for $SCHEMA_DIR."
      fi
    done
    if [ $SCHEMA_EXIT -ne 0 ]; then
      exit 1
    fi
  fi
else
  print_warning "No 'test:schemas' script found – skipping schema tests."
fi

# ── 3. Security audit ────────────────────────────────────────────────────────
print_info "Running security audit…"
npm audit --audit-level=moderate
AUDIT_EXIT=$?
if [ $AUDIT_EXIT -ne 0 ]; then
  print_warning "Security vulnerabilities found."
  printf "Continue push anyway? (y/n) "
  read -r REPLY
  case "$REPLY" in
    [Yy]*) print_info "Continuing push despite vulnerabilities." ;;
    *)     print_error "Push aborted. Fix vulnerabilities or use 'git push --no-verify' to bypass."; exit 1 ;;
  esac
else
  print_success "No security vulnerabilities found."
fi

# ── Done ──────────────────────────────────────────────────────────────────────
print_success "All pre-push checks passed. Proceeding with push."
exit 0
