{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "erasableSyntaxOnly": true
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": [
    "node_modules",
    "services/oss-files/oss-uploader-usage.ts",
    "services/oss-files/s3-uploader-usage.ts",
    "services/oss-files/oss-uploader-server.ts",
    "services/oss-files/s3-uploader-server.ts"
  ]
}
