{
  "name": "@common/node",
  "version": "0.0.2",
  "author": "Aaron Gong",
  "license": "MIT",
  "description": "Shareable Node Runtime JS library using ES modules",
  "keywords": [
    "javscript",
    "module"
  ],
  "homepage": "https://github.com/ais-one/novex-kit#readme",
  "bugs": {
    "url": "https://github.com/ais-one/novex-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ais-one/novex-kit.git"
  },
  "type": "module",
  "exports": {
    "./auth": "./auth/index.ts",
    "./logger": "./logger.ts",
    "./services": "./services/index.ts",
    "./*": "./*.ts",
    "./**/*": "./**/*.ts"
  },
  "main": "logger.ts",
  "scripts": {
    "test": "node --experimental-test-coverage --test-reporter=spec --test __test__/*.test.ts",
    "cover": "node --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test __test__/*.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@node-saml/node-saml": "^5.1.0",
    "@openfga/sdk": "^0.9.5",
    "@scalar/express-api-reference": "^0.9.9",
    "@types/connect-history-api-fallback": "^1.5.4",
    "@types/multer": "^2.1.0",
    "@types/serve-index": "^1.9.4",
    "@types/web-push": "^3.6.4",
    "ali-oss": "^6.23.0",
    "connect-history-api-fallback": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.6.0",
    "knex": "^3.2.9",
    "multer": "^2.1.1",
    "mysql": "^2.18.1",
    "otplib": "^13.4.0",
    "path-to-regexp": "^8.4.2",
    "pg": "^8.20.0",
    "serve-index": "^1.9.2",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-fetch": "^2.6.13",
    "@types/ws": "^8.18.1"
  }
}
